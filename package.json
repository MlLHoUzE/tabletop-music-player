{
  "name": "obsidian-ttrpg-music-player",
  "version": "1.0.0",
  "description": "TTRPG audio controller with front matter filtering.",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild main.ts --bundle --outfile=main.js --watch --external:obsidian --format=cjs --minify=false",
    "build": "esbuild main.ts --bundle --outfile=main.js --external:obsidian --format=cjs --minify",
    "lint": "eslint **/*.ts",
    "format": "prettier --write \"**/*.{ts,css,json,md}\""
  },
  "keywords": [
    "obsidian",
    "plugin",
    "ttrpg",
    "audio"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "esbuild": "^0.20.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "obsidian": "^1.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.0.0"
  }
}
